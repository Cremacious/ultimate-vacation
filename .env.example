# TripWave — environment variables
# Copy this file to .env.local (gitignored) and fill in real values.

# Neon Postgres connection string. Use the DEV branch for local development.
# Get it from: Neon dashboard → Project → Branches → dev → Connection string (pooled).
# Format: postgresql://user:password@ep-xxxxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Better Auth — server-side secret used to sign session tokens.
# Generate with: `openssl rand -base64 32` (or any 32+ char random string).
BETTER_AUTH_SECRET=

# Public base URL the auth client + server use to build callback URLs.
# Dev: http://localhost:3000   Prod: https://tripwave.app (or your domain).
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# PostHog analytics (server-side). Get the key from posthog.com → Project Settings → API Keys.
# When absent, all emit() calls fall back to console.log silently — no crash.
# POSTHOG_HOST defaults to https://us.i.posthog.com; set to https://eu.i.posthog.com for EU.
POSTHOG_API_KEY=
POSTHOG_HOST=

# Admin gate for /app/admin (retention dashboard). Set to your own email address.
# If absent, /app/admin redirects all visitors to /app.
ADMIN_EMAIL=
